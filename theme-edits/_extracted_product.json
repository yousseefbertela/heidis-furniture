        "custom_liquid_JttMgb": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% if product.selected_variant %}\n  <p class=\"one\" id=\"variant-sku\" data-product-sku=\"{{ product.selected_variant.sku }}\">SKU: {{ product.selected_variant.sku }}</p>\n{% else %}\n  {% if product.variants.first.sku %}\n    <p class=\"two\" id=\"variant-sku\" data-product-sku=\"{{ product.sku }}\">SKU: {{ product.variants.first.sku }}</p>\n  {% else %}\n    <p class=\"thre\" id=\"variant-sku\"></p>\n  {% endif %}\n{% endif %}\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n    // Get the SKU element\n    var skuElement = document.getElementById('variant-sku');\n\n    // Add event listeners to variant radios\n    var variantRadios = document.querySelectorAll('.product-form__radio');\n    variantRadios.forEach(function(radio) {\n        radio.addEventListener('change', function() {\n            // Get the variant ID from the data attribute\n            var variantId = this.getAttribute('data-variant-id'); \n            // Get the variant SKU\n            var variant = getProductVariant(variantId);\n            var sku = variant ? variant.sku : '';\n            // Update the SKU element\n            skuElement.innerText = 'SKU: ' + sku;\n        });\n    });\n});\n\nfunction getProductVariant(variantId) {\n    // Parse the JSON data attribute to get the variant information\n    var variantData = JSON.parse(document.querySelector('variant-radios script').innerText);\n    // Find the variant by ID and return it\n    return variantData.find(function(variant) {\n        return variant.id == variantId;\n    });\n}\n</script>"
          }
        },

{%- comment -%}
  Hedi's home — shared base for the modular homepage sections (hero, promo,
  category carousel, editorial split, story). Rendered once by each section:
  loads the display fonts, the shared design tokens/classes (.hh-*), and the
  scroll-reveal + carousel JS. Safe to render multiple times (JS self-guards).
{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap">

{% stylesheet %}
  .hh-home {
    --ink: #232323;
    --accent: #8c6e45;
    --muted: #6f6a63;
    --bg: #ffffff;
    color: var(--ink);
    background: var(--bg);
    font-family: "Jost", "Helvetica Neue", Arial, sans-serif;
    font-weight: 300;
    overflow: hidden;
  }
  .hh-home * { box-sizing: border-box; }
  .hh-home h1, .hh-home h2, .hh-home h3 {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 500;
    line-height: 1.04;
    margin: 0;
    color: var(--ink);
  }
  .hh-home a { color: inherit; text-decoration: none; }
  .hh-home img { display: block; max-width: none; }
  .hh-wrap { max-width: 1400px; margin: 0 auto; padding: 0 40px; }
  .hh-kick { margin: 0 0 18px; font-size: 11px; letter-spacing: .32em; text-transform: uppercase; color: var(--accent); font-weight: 400; }
  .hh-btn { display: inline-block; margin-top: 30px; padding: 16px 40px; border: 1px solid currentColor; font-size: 11px; letter-spacing: .24em; text-transform: uppercase; font-weight: 400; transition: all .45s ease; background: transparent; cursor: pointer; }
  .hh-btn:hover { background: var(--ink); color: #fff; border-color: var(--ink); }
  .hh-btn--light { background: #fff; color: var(--ink); border-color: #fff; text-shadow: none; box-shadow: 0 2px 18px rgba(0,0,0,.18); }
  .hh-btn--light:hover { background: transparent; color: #fff; border-color: #fff; box-shadow: none; }
  .hh-rv { opacity: 0; transform: translateY(34px); transition: opacity 1.1s ease, transform 1.1s ease; }
  .hh-rv.in { opacity: 1; transform: none; }
  .hh-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .hh-head h2 { font-size: clamp(34px, 4vw, 58px); }
  .hh-head p { margin: 18px auto 0; max-width: 48ch; color: var(--muted); font-size: 15px; line-height: 1.8; }
  .hh-sec { padding: 120px 0 60px; }
  @media (max-width: 1024px) { .hh-sec { padding: 84px 0 44px; } }
  @media (max-width: 600px) { .hh-wrap { padding: 0 22px; } }
{% endstylesheet %}

<script>
(function(){
  if (window.__hhHome) return; window.__hhHome = 1;
  function reveal(scope){
    var els = (scope || document).querySelectorAll('.hh-rv:not(.in)');
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); }, { threshold: 0.08 });
      els.forEach(function(el){ io.observe(el); });
    } else { els.forEach(function(el){ el.classList.add('in'); }); }
  }
  document.addEventListener('click', function(e){
    var btn = e.target.closest && e.target.closest('.hh-nav'); if(!btn) return;
    var rail = document.getElementById(btn.getAttribute('data-rail')); if(!rail) return;
    var first = rail.children[0];
    var step = first ? (first.getBoundingClientRect().width + 18) : Math.round(rail.clientWidth * 0.6);
    rail.scrollBy({ left: btn.classList.contains('hh-nav--prev') ? -step : step, behavior: 'smooth' });
  });
  if (document.readyState !== 'loading') reveal(document);
  else document.addEventListener('DOMContentLoaded', function(){ reveal(document); });
  document.addEventListener('shopify:section:load', function(e){ reveal(e.target); });
})();
</script>

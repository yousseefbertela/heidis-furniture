    { "type": "text", "id": "room_3_title", "label": "Tile 3 title", "default": "Tables" },
    { "type": "url", "id": "room_3_link", "label": "Tile 3 link" },
    { "type": "text", "id": "room_4_image_url", "label": "Tile 4 image", "default": "https://cdn.shopify.com/s/files/1/0560/2600/5592/files/close-up-of-huxley-sofa-stitch-work-and-fabric-weave-in-cozyreadingnook-fulfily-1.jpg?v=1780164479" },

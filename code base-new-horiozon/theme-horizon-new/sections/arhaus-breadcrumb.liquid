{%- comment -%} Arhaus-style PDP breadcrumb: "‹ Back | Home / Product". Self-contained. {%- endcomment -%}
<nav class="ah-breadcrumb" aria-label="Breadcrumb">
  <a href="#" class="ah-bc-back" onclick="if(history.length>1){history.back();}return false;">&lsaquo;&nbsp;Back</a>
  <span class="ah-bc-sep">|</span>
  <a href="{{ routes.root_url }}" class="ah-bc-home">Home</a>
  <span class="ah-bc-sep">/</span>
  <span class="ah-bc-current">{{ product.title }}</span>
</nav>
<style>
  /* Make the breadcrumb section white — matches the white PDP below */
  .shopify-section:has(.ah-breadcrumb) {
    background: #ffffff !important;
  }
  .ah-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px clamp(16px, 1.6vw, 26px);
    font-family: "Jost", "Helvetica Neue", Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.03em;
    color: #6f6a63;
    background: transparent;
  }
  .ah-breadcrumb a { color: #6f6a63; text-decoration: none; }
  .ah-breadcrumb a:hover { color: #1b1b1b; }
  .ah-breadcrumb .ah-bc-back { font-weight: 500; color: #1b1b1b; }
  .ah-breadcrumb .ah-bc-sep { color: #c9c4bb; }
  .ah-breadcrumb .ah-bc-current { color: #1b1b1b; }
  @media screen and (max-width: 749px) {
    .ah-breadcrumb { padding-inline: 16px; }
  }
</style>
{% schema %}
{
  "name": "Arhaus Breadcrumb",
  "settings": [],
  "presets": [{ "name": "Arhaus Breadcrumb" }]
}
{% endschema %}

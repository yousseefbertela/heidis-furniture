{%- comment -%} Arhaus-style footer for Hedi's Furniture (Horizon). Self-contained: own CSS + content. v2 {%- endcomment -%}
{%- liquid
  assign teal = section.settings.teal_color
  assign dark = section.settings.dark_color
-%}
<style>
  #af-{{ section.id }}{ font-family:"Jost","Helvetica Neue",Arial,sans-serif; }
  #af-{{ section.id }} *{ box-sizing:border-box; }
  #af-{{ section.id }} a{ color:inherit; text-decoration:none; }

  /* MAP */
  #af-{{ section.id }} .af-map{ width:100%; line-height:0; }
  #af-{{ section.id }} .af-map iframe{ width:100%; height:300px; border:0; display:block; }

  /* TEAL BAND */
  #af-{{ section.id }} .af-band{ background:{{ teal }}; color:#fff; }
  #af-{{ section.id }} .af-band__in{ max-width:1280px; margin:0 auto; padding:26px 24px; display:grid; grid-template-columns:repeat(3,1fr); }
  #af-{{ section.id }} .af-band__item{ display:flex; align-items:center; justify-content:center; gap:12px; font-size:14px; letter-spacing:.04em; text-align:center; position:relative; }
  #af-{{ section.id }} .af-band__item + .af-band__item::before{ content:""; position:absolute; left:0; top:50%; transform:translateY(-50%); height:34px; width:1px; background:rgba(255,255,255,.25); }
  #af-{{ section.id }} .af-band__icon{ width:26px; height:26px; flex:0 0 auto; stroke:#fff; fill:none; stroke-width:1.5; }

  /* DARK FOOTER */
  #af-{{ section.id }} .af-main{ background:{{ dark }}; color:#b7b2ab; }
  #af-{{ section.id }} .af-main__in{ max-width:1280px; margin:0 auto; padding:64px 24px 40px; display:grid; grid-template-columns:1.5fr 1fr 1fr 1.2fr 1.5fr; gap:40px; }
  #af-{{ section.id }} .af-col h4{ color:#fff; font-size:13px; font-weight:500; letter-spacing:.16em; text-transform:uppercase; margin:0 0 20px; font-family:"Jost","Helvetica Neue",Arial,sans-serif; }
  #af-{{ section.id }} .af-col ul{ list-style:none; margin:0; padding:0; }
  #af-{{ section.id }} .af-col li{ margin-bottom:11px; }
  #af-{{ section.id }} .af-col a{ font-size:13.5px; color:#b7b2ab; letter-spacing:.02em; transition:color .2s ease; }
  #af-{{ section.id }} .af-col a:hover{ color:#fff; }

  #af-{{ section.id }} .af-addr{ font-size:13.5px; line-height:1.7; color:#b7b2ab; margin:0 0 18px; font-style:normal; }
  #af-{{ section.id }} .af-contact{ display:flex; align-items:center; gap:10px; margin-bottom:10px; font-size:13.5px; }
  #af-{{ section.id }} .af-contact svg{ width:15px; height:15px; stroke:#9a958d; fill:none; stroke-width:1.6; flex:0 0 auto; }
  #af-{{ section.id }} .af-follow{ margin-top:22px; }
  #af-{{ section.id }} .af-follow__label{ color:#fff; font-size:12px; letter-spacing:.16em; text-transform:uppercase; margin:0 0 14px; }
  #af-{{ section.id }} .af-social{ display:flex; gap:12px; }
  #af-{{ section.id }} .af-social a{ width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
  #af-{{ section.id }} .af-social svg{ width:17px; height:17px; fill:#fff; }
  #af-{{ section.id }} .af-social--fb{ background:#3b5998; }
  #af-{{ section.id }} .af-social--ig{ background:#000; }
  #af-{{ section.id }} .af-social--pin{ background:#e60023; }

  /* NEWSLETTER */
  #af-{{ section.id }} .af-news p{ font-size:13.5px; line-height:1.7; margin:0 0 18px; color:#b7b2ab; }
  #af-{{ section.id }} .af-news form{ display:flex; max-width:330px; }
  #af-{{ section.id }} .af-news input[type=email]{ flex:1; background:#2a2a2a; border:1px solid #3a3a3a; color:#fff; padding:12px 14px; font-size:13px; font-family:inherit; outline:none; }
  #af-{{ section.id }} .af-news input[type=email]::placeholder{ color:#8a857e; }
  #af-{{ section.id }} .af-news button{ background:{{ teal }}; color:#fff; border:0; padding:12px 22px; font-size:12px; letter-spacing:.12em; text-transform:uppercase; cursor:pointer; font-family:inherit; }
  #af-{{ section.id }} .af-news button:hover{ background:#1f5260; }

  /* BOTTOM */
  #af-{{ section.id }} .af-bottom{ background:{{ dark }}; border-top:1px solid #2c2c2c; }
  #af-{{ section.id }} .af-bottom__in{ max-width:1280px; margin:0 auto; padding:22px 24px; display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap; }
  #af-{{ section.id }} .af-copy{ font-size:12px; color:#8a857e; letter-spacing:.03em; }
  #af-{{ section.id }} .af-pays{ display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
  #af-{{ section.id }} .af-pays svg, #af-{{ section.id }} .af-pays img{ height:24px; width:auto; }

  @media (max-width:1024px){ #af-{{ section.id }} .af-main__in{ grid-template-columns:1fr 1fr; gap:36px; } }
  @media (max-width:600px){
    #af-{{ section.id }} .af-band__in{ grid-template-columns:1fr; gap:18px; }
    #af-{{ section.id }} .af-band__item + .af-band__item::before{ display:none; }
    #af-{{ section.id }} .af-main__in{ grid-template-columns:1fr; }
    #af-{{ section.id }} .af-bottom__in{ flex-direction:column; align-items:flex-start; }
  }
</style>

<div id="af-{{ section.id }}">
  {%- if section.settings.show_map -%}
    <div class="af-map">
      <iframe title="Store location map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
        src="https://maps.google.com/maps?q={{ section.settings.map_query | url_encode }}&z=11&output=embed"></iframe>
    </div>
  {%- endif -%}

  <div class="af-band">
    <div class="af-band__in">
      <div class="af-band__item">
        <svg class="af-band__icon" viewBox="0 0 24 24"><path d="M1 4h13v11H1zM14 8h4l3 3v4h-7zM5.5 18.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM17.5 18.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/></svg>
        <span>{{ section.settings.promo_1 }}</span>
      </div>
      <div class="af-band__item">
        <svg class="af-band__icon" viewBox="0 0 24 24"><path d="M3 9l4-4M3 9l4 4M3 9h11a6 6 0 0 1 0 12h-3"/></svg>
        <span>{{ section.settings.promo_2 }}</span>
      </div>
      <div class="af-band__item">
        <svg class="af-band__icon" viewBox="0 0 24 24"><path d="M12 3l8 3v5c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6z"/></svg>
        <span>{{ section.settings.promo_3 }}</span>
      </div>
    </div>
  </div>

  <div class="af-main">
    <div class="af-main__in">
      <div class="af-col af-col--brand">
        <address class="af-addr">{{ section.settings.address_line1 }}<br>{{ section.settings.address_line2 }}</address>
        <div class="af-contact"><svg viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg><a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a></div>
        <div class="af-contact"><svg viewBox="0 0 24 24"><path d="M4 4h16v16H4zM4 6l8 6 8-6"/></svg><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></div>
        <div class="af-follow">
          <p class="af-follow__label">Follow Us</p>
          <div class="af-social">
            <a class="af-social--fb" href="{{ section.settings.facebook_url }}" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.8 3.7-3.8 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.5V12h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg></a>
            <a class="af-social--ig" href="{{ section.settings.instagram_url }}" aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.3 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .3-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.3-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.3 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 1.6c-3.1 0-3.5 0-4.7.1-1.1.1-1.7.2-2.1.4-.5.2-.9.4-1.2.8-.4.3-.6.7-.8 1.2-.2.4-.3 1-.4 2.1-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.7.4 2.1.2.5.4.9.8 1.2.3.4.7.6 1.2.8.4.2 1 .3 2.1.4 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.7-.2 2.1-.4.5-.2.9-.4 1.2-.8.4-.3.6-.7.8-1.2.2-.4.3-1 .4-2.1.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.7-.4-2.1-.2-.5-.4-.9-.8-1.2-.3-.4-.7-.6-1.2-.8-.4-.2-1-.3-2.1-.4-1.2-.1-1.6-.1-4.7-.1zm0 2.7a5.3 5.3 0 1 1 0 10.6 5.3 5.3 0 0 1 0-10.6zm0 1.6a3.7 3.7 0 1 0 0 7.4 3.7 3.7 0 0 0 0-7.4zm5.5-.9a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z"/></svg></a>
            <a class="af-social--pin" href="{{ section.settings.pinterest_url }}" aria-label="Pinterest"><svg viewBox="0 0 24 24"><path d="M12 2C6.5 2 4 5.6 4 8.9c0 2 .8 3.7 2.4 4.4.3.1.5 0 .5-.3l.2-.9c.1-.2 0-.3-.1-.5-.4-.5-.6-1.1-.6-1.9 0-2.4 1.8-4.6 4.7-4.6 2.6 0 4 1.6 4 3.7 0 2.8-1.2 5.1-3 5.1-1 0-1.7-.8-1.5-1.8.3-1.2.8-2.5.8-3.3 0-.8-.4-1.4-1.3-1.4-1 0-1.9 1.1-1.9 2.5 0 .9.3 1.5.3 1.5l-1.2 5.1c-.3 1.5-.1 3.3 0 3.5 0 .1.2.2.3.1.1-.1 1.6-2 2.1-3.8l.8-3c.4.7 1.5 1.4 2.6 1.4 3.5 0 5.9-3.2 5.9-7.4C20.5 5.1 17.6 2 12 2z"/></svg></a>
          </div>
        </div>
      </div>

      <div class="af-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/living">Living</a></li>
          <li><a href="/collections/dining">Dining</a></li>
          <li><a href="/collections/bedroom">Bedroom</a></li>
          <li><a href="/collections/outdoor">Outdoor</a></li>
          <li><a href="/collections/lighting">Lighting</a></li>
          <li><a href="/collections/decor">Decor</a></li>
          <li><a href="/collections/rugs">Rugs</a></li>
          <li><a href="/collections/office">Office</a></li>
        </ul>
      </div>

      <div class="af-col">
        <h4>Further Info</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/pages/about-us">About Hedis</a></li>
          <li><a href="/pages/trade-program">Trade Program</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/blogs/news">Blog</a></li>
          <li><a href="/pages/sitemap">Sitemap</a></li>
        </ul>
      </div>

      <div class="af-col">
        <h4>Customer Service</h4>
        <ul>
          <li><a href="/pages/faqs">FAQs</a></li>
          <li><a href="/pages/returns-exchanges">Returns &amp; Exchanges</a></li>
          <li><a href="/pages/limited-warranty">Limited Warranty</a></li>
          <li><a href="/pages/delivery-shipping">Delivery &amp; Shipping</a></li>
          <li><a href="/policies/terms-of-service">Terms Of Service</a></li>
          <li><a href="/pages/contact">Contact Information</a></li>
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
        </ul>
      </div>

      <div class="af-col af-news">
        <h4>Newsletter Sign Up</h4>
        <p>{{ section.settings.newsletter_text }}</p>
        {%- form 'customer' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="Email address" required>
          <button type="submit">Subscribe</button>
        {%- endform -%}
      </div>
    </div>

    <div class="af-bottom">
      <div class="af-bottom__in">
        <p class="af-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }} All Rights Reserved.</p>
        <div class="af-pays">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'af-pay-icon' }}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Arhaus Footer",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "teal_color", "label": "Promo band / accent", "default": "#2A6876" },
    { "type": "color", "id": "dark_color", "label": "Footer background", "default": "#1A1A1A" },
    { "type": "header", "content": "Map" },
    { "type": "checkbox", "id": "show_map", "label": "Show map", "default": true },
    { "type": "text", "id": "map_query", "label": "Map address", "default": "199 Boylston St, Chestnut Hill, MA 02467" },
    { "type": "header", "content": "Promo band" },
    { "type": "text", "id": "promo_1", "label": "Item 1", "default": "Free Shipping US Order $100" },
    { "type": "text", "id": "promo_2", "label": "Item 2", "default": "Free Returns*" },
    { "type": "text", "id": "promo_3", "label": "Item 3", "default": "Lifetime Warranty Guarantee*" },
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "address_line1", "label": "Address line 1", "default": "199 Boylston st., N 231" },
    { "type": "text", "id": "address_line2", "label": "Address line 2", "default": "Chestnut Hill, MA 02467" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+1 774-440-1603" },
    { "type": "text", "id": "email", "label": "Email", "default": "info@hedisfurniture.com" },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_text", "label": "Text", "default": "Receive our latest updates about our products & promotions." },
    { "type": "header", "content": "Social" },
    { "type": "text", "id": "facebook_url", "label": "Facebook URL", "default": "https://www.facebook.com/" },
    { "type": "text", "id": "instagram_url", "label": "Instagram URL", "default": "https://www.instagram.com/" },
    { "type": "text", "id": "pinterest_url", "label": "Pinterest URL", "default": "https://www.pinterest.com/" }
  ],
  "presets": [ { "name": "Arhaus Footer" } ]
}
{% endschema %}

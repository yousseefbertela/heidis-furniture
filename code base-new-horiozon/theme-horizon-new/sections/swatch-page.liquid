{%- liquid
  # Resolve the sample variant: prefer the picked product, fall back to the id setting.
  assign sample_variant_id = ''
  if section.settings.sample_product != blank
    assign sample_variant_id = section.settings.sample_product.selected_or_first_available_variant.id
  endif
  if sample_variant_id == blank
    assign sample_variant_id = section.settings.sample_variant_id
  endif
  assign max_swatches = section.settings.max_swatches | default: 5
-%}
<div class="section-background"></div>
<div class="section page-width-normal">
  <div class="spacing-style section-content-wrapper" style="{% render 'spacing-style', settings: section.settings %}">
    <section
      class="swatch-page"
      data-sample-variant-id="{{ sample_variant_id }}"
      data-max-swatches="{{ max_swatches }}"
    >
      <div class="swatch-page-content">
        <h2 class="swatch-page-title">{{ page.title | default: 'Order Swatches' }}</h2>

        <div class="swatches-grid">
          {%- assign swatch_collection = collections['upholstery-swatches'] -%}
          {%- if swatch_collection and swatch_collection.products.size > 0 -%}
            {%- for product in swatch_collection.products -%}
              {%- assign swatch_handle = product.title | handle -%}
              {%- assign matched_color = metaobjects['shopify--color-pattern'].values | where: "handle", swatch_handle | first -%}
              {%- assign color_info = metaobjects['color_info'].values | where: "color", matched_color.id | first -%}

              <div class="swatch-item" data-swatch-id="{{ product.id }}">
                <div class="swatch-image">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title | escape }}" loading="lazy" width="300" height="260">
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                  <button
                    class="add-swatch-button"
                    data-swatch-id="{{ product.id }}"
                    data-option-value="{{ product.title | escape }}"
                    aria-label="Add {{ product.title | escape }} to your swatch order"
                  >
                    +
                  </button>
                </div>

                <div class="swatch-details">
                  <h4>{{ product.title }}</h4>
                  <div class="swatch-info" data-swatch-code="{{ color_info.color_code | default: product.variants.first.sku | default: product.title }}">
                    <div><strong>Pattern:</strong> {{ color_info.pattern | default: 'Plain/Solid' }}</div>
                    <div><strong>Cleaning Code:</strong> {{ color_info.cleaning_code | default: 'N/A' }}</div>
                    <div><strong>Fabric Content:</strong> {{ color_info.fabric_content | default: 'N/A' }}</div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- assign fallback_titles = "11168-58|FEDERAL BLUE|GREY|LIGHT GREY|MEDITERRANEAN|MINERAL|PUTTY|VR300-52|VR310-22|VR316-88" | split: "|" -%}
            {%- assign fallback_images = "11168-58.png|fedral-blue.png|grey.png|light-grey.png|medit-rranean.png|mineral.png|putty_b43e94e8-7436-4233-a7df-9d94fc83421d.png|VR300-52.jpg|vr310-22.png|vr316-88.png" | split: "|" -%}
            {%- assign fallback_codes = "11168-58|VR310-52|VR303-10|ST101-10|VR309-69|ST102-87|VR316-75|VR300-52/T|VR310-22/Q|VR316-88/Q" | split: "|" -%}
            {%- assign fallback_patterns = "RS|Plain/Solid|Plain/Solid|Plain/Solid|Plain/Solid|Plain/Solid|Plain/Solid|Plain/Solid|Plain/Solid|Plain/Solid" | split: "|" -%}
            {%- assign fallback_cleanings = "S|W/S|W|W|W/S|W|W/S|W|W/S|W/S" | split: "|" -%}
            {%- assign fallback_contents = "55% LINEN, 45% RAYON|100% OLEFIN|100% OLEFIN|100% POLYPROPYLENE|100% OLEFIN|100% POLYPROPYLENE|77% OLEFIN 23% UV POLYESTER|99% Olefin, 1% Polyester|100% OLEFIN|77% Olefin, 23% UV Polyester" | split: "|" -%}

            {%- for title in fallback_titles -%}
              {%- assign idx = forloop.index0 -%}
              {%- assign image_name = fallback_images[idx] -%}
              {%- assign code = fallback_codes[idx] -%}
              {%- assign pattern = fallback_patterns[idx] -%}
              {%- assign cleaning = fallback_cleanings[idx] -%}
              {%- assign content = fallback_contents[idx] -%}

              <div class="swatch-item" data-swatch-id="fallback-{{ idx }}">
                <div class="swatch-image">
                  <img src="{{ image_name | file_img_url: '300x' }}" alt="{{ title | escape }}" loading="lazy" width="300" height="260">
                  <button
                    class="add-swatch-button"
                    data-swatch-id="fallback-{{ idx }}"
                    data-option-value="{{ title | escape }}"
                    aria-label="Add {{ title | escape }} to your swatch order"
                  >
                    +
                  </button>
                </div>

                <div class="swatch-details">
                  <h4>{{ title }}</h4>
                  <div class="swatch-info" data-swatch-code="{{ code }}">
                    <div><strong>Pattern:</strong> {{ pattern }}</div>
                    <div><strong>Cleaning Code:</strong> {{ cleaning }}</div>
                    <div><strong>Fabric Content:</strong> {{ content }}</div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <div class="swatch-selection-bar">
          <span class="swatch-selection-label">Select up to {{ max_swatches }}</span>
          <div class="swatch-selection-preview">
            {%- for i in (1..max_swatches) -%}
              <div class="preview-slot" data-slot="{{ i }}"></div>
            {%- endfor -%}
          </div>
        </div>

        <p class="swatch-page-message" id="swatch-page-message" role="status" aria-live="polite" hidden></p>

        <div class="swatch-page-footer">
          <button type="button" class="order-swatches-submit" id="order-swatches-submit">ORDER SWATCHES</button>
        </div>
      </div>
    </section>
  </div>
</div>

{% stylesheet %}
  .swatch-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .swatch-page-title {
    font-family: var(--font-heading--family, "Cormorant Garamond", serif);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 400;
    text-align: center;
    color: #1b1b1b;
    margin-bottom: 32px;
    letter-spacing: 0.02em;
    text-transform: capitalize;
  }

  .swatches-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 24px;
  }

  @media screen and (min-width: 750px) {
    .swatches-grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 24px;
    }
  }

  .swatch-item {
    background: #fff;
    border: 1px solid #e3ded6;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.25s ease;
    position: relative;
  }

  .swatch-item:hover {
    border-color: #1e3d2f;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .swatch-item.selected {
    border-color: #1e3d2f;
    box-shadow: 0 0 0 2px #1e3d2f;
  }

  .swatch-image {
    position: relative;
    aspect-ratio: 1.15;
    overflow: hidden;
    background: #f5f4f0;
  }

  .swatch-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .swatch-item:hover .swatch-image img {
    transform: scale(1.04);
  }

  .add-swatch-button {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid #d9d5cf;
    font-size: 20px;
    line-height: 1;
    color: #1e3d2f;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    font-family: var(--font-body--family, "Jost", sans-serif);
    font-weight: 400;
    z-index: 2;
  }

  .add-swatch-button:hover {
    background: #1e3d2f;
    color: #fff;
    border-color: #1e3d2f;
  }

  .add-swatch-button.selected {
    background: #1e3d2f;
    color: #fff;
    border-color: #1e3d2f;
    font-size: 14px;
  }

  .swatch-details {
    padding: 12px 14px;
  }

  .swatch-details h4 {
    font-family: var(--font-body--family, "Jost", sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #1b1b1b;
    margin: 0 0 6px;
  }

  .swatch-info {
    font-family: var(--font-body--family, "Jost", sans-serif);
    font-size: 11px;
    line-height: 1.5;
    color: #4a4641;
  }

  .swatch-info div {
    margin-bottom: 2px;
  }

  .swatch-info strong {
    font-weight: 600;
    color: #1b1b1b;
  }

  /* ---- Selection bar (sticky bottom) ---- */
  .swatch-selection-bar {
    position: sticky;
    bottom: 0;
    background: #fff;
    border-top: 1px solid #e3ded6;
    padding: 16px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    z-index: 5;
    margin-top: 12px;
  }

  .swatch-selection-label {
    font-family: var(--font-body--family, "Jost", sans-serif);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #4a4641;
  }

  .swatch-selection-preview {
    display: flex;
    gap: 8px;
  }

  .preview-slot {
    width: 40px;
    height: 40px;
    border: 1px dashed #d9d5cf;
    border-radius: 4px;
    overflow: hidden;
    background: #fafaf8;
    transition: border-color 0.2s ease;
  }

  .preview-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---- Inline message ---- */
  .swatch-page-message {
    margin: 12px 0 0;
    text-align: center;
    font-family: var(--font-body--family, "Jost", sans-serif);
    font-size: 13px;
    color: #b3261e;
  }

  .swatch-page-message[hidden] {
    display: none;
  }

  /* ---- Footer / order button ---- */
  .swatch-page-footer {
    text-align: center;
    padding: 24px 0 40px;
  }

  .order-swatches-submit {
    display: inline-block;
    width: 100%;
    max-width: 400px;
    padding: 14px 32px;
    background: #1e3d2f;
    color: #fff;
    border: none;
    border-radius: 0;
    font-family: var(--font-body--family, "Jost", sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, opacity 0.2s ease;
  }

  .order-swatches-submit:hover {
    background: #163028;
  }

  .order-swatches-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const root = document.querySelector('.swatch-page');
    if (!root) return;

    const MAX_SWATCHES = parseInt(root.dataset.maxSwatches, 10) || 5;
    const SAMPLE_VARIANT_ID = (root.dataset.sampleVariantId || '').trim();

    const selectedSwatches = new Map();
    const addSwatchButtons = root.querySelectorAll('.add-swatch-button');
    const swatchItems = root.querySelectorAll('.swatch-item');
    const orderButton = document.getElementById('order-swatches-submit');
    const previewSlots = root.querySelectorAll('.preview-slot');
    const messageEl = document.getElementById('swatch-page-message');

    let messageTimer;
    function flash(text) {
      if (!messageEl) return;
      messageEl.textContent = text;
      messageEl.hidden = false;
      clearTimeout(messageTimer);
      messageTimer = setTimeout(function () {
        messageEl.hidden = true;
        messageEl.textContent = '';
      }, 3500);
    }

    function clearMessage() {
      if (!messageEl) return;
      clearTimeout(messageTimer);
      messageEl.hidden = true;
      messageEl.textContent = '';
    }

    function cartUrl() {
      return (window.Theme && Theme.routes && Theme.routes.cart_url) || '/cart';
    }

    function updatePreview() {
      previewSlots.forEach(function (slot) {
        slot.innerHTML = '';
      });

      let i = 0;
      selectedSwatches.forEach(function (optionValue) {
        if (i < previewSlots.length) {
          const button = root.querySelector('.add-swatch-button[data-option-value="' + optionValue + '"]');
          if (!button) return;
          const sourceImg = button.closest('.swatch-item').querySelector('img');
          if (!sourceImg) return;
          const img = sourceImg.cloneNode(true);
          img.style.objectFit = 'cover';
          previewSlots[i].appendChild(img);
          i++;
        }
      });
    }

    function toggleSwatch(optionValue, button) {
      const item = button.closest('.swatch-item');
      if (selectedSwatches.has(optionValue)) {
        selectedSwatches.delete(optionValue);
        button.textContent = '+';
        button.classList.remove('selected');
        if (item) item.classList.remove('selected');
      } else {
        if (selectedSwatches.size >= MAX_SWATCHES) {
          flash('You can select up to ' + MAX_SWATCHES + ' swatches.');
          return;
        }
        selectedSwatches.set(optionValue, optionValue);
        button.textContent = '✓';
        button.classList.add('selected');
        if (item) item.classList.add('selected');
        clearMessage();
      }
      updatePreview();

      orderButton.textContent =
        selectedSwatches.size > 0
          ? 'ORDER ' + selectedSwatches.size + ' SWATCH' + (selectedSwatches.size > 1 ? 'ES' : '')
          : 'ORDER SWATCHES';
    }

    addSwatchButtons.forEach(function (button) {
      button.addEventListener('click', function (e) {
        e.stopPropagation();
        toggleSwatch(this.dataset.optionValue, this);
      });
    });

    swatchItems.forEach(function (item) {
      item.addEventListener('click', function () {
        const button = this.querySelector('.add-swatch-button');
        if (!button) return;
        toggleSwatch(button.dataset.optionValue, button);
      });
    });

    orderButton.addEventListener('click', function () {
      if (selectedSwatches.size === 0) {
        flash('Please select at least one swatch to order.');
        return;
      }
      if (!SAMPLE_VARIANT_ID) {
        flash('Swatch ordering is unavailable right now.');
        return;
      }

      const items = Array.from(selectedSwatches.values()).map(function (optionValue) {
        const button = root.querySelector('.add-swatch-button[data-option-value="' + optionValue + '"]');
        const swatchItem = button ? button.closest('.swatch-item') : null;
        const info = swatchItem ? swatchItem.querySelector('.swatch-info') : null;
        const swatchCode = (info && info.dataset.swatchCode) || 'N/A';

        return {
          id: Number(SAMPLE_VARIANT_ID),
          quantity: 1,
          properties: {
            Swatch: optionValue,
            Code: swatchCode,
            _swatch_sample: 'true',
          },
        };
      });

      orderButton.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items }),
      })
        .then(function (res) {
          return res.json();
        })
        .then(function (data) {
          orderButton.disabled = false;
          if (data && data.status) {
            // Shopify returns a non-zero `status` on error (e.g. sold out).
            flash(data.description || data.message || 'Something went wrong. Please try again.');
            return;
          }
          // Take the shopper to the cart to review — never straight to checkout.
          window.location.href = cartUrl();
        })
        .catch(function (err) {
          orderButton.disabled = false;
          console.error('[swatch-page] add to cart failed', err);
          flash('Something went wrong. Please try again.');
        });
    });
  });
</script>

{% schema %}
{
  "name": "Swatch Page",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Sample product"
    },
    {
      "type": "product",
      "id": "sample_product",
      "label": "Sample product",
      "info": "The product added to cart for each swatch (e.g. a $5 \"Sample Swatch\"). If empty, the variant ID below is used."
    },
    {
      "type": "text",
      "id": "sample_variant_id",
      "label": "Sample variant ID (fallback)",
      "default": "43130775732312"
    },
    {
      "type": "range",
      "id": "max_swatches",
      "label": "Maximum swatches per order",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}

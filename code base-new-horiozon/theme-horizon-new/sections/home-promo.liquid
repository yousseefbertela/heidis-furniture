{%- comment -%} Hedi's home — Promo banner. Tall image with headline + button near the top. {%- endcomment -%}
{% render 'hedis-home-base' %}
{%- liquid
  assign img = section.settings.image
  assign img_src = section.settings.image_url
  if img != blank
    assign img_src = img | image_url: width: 2600
  endif
  assign tc = section.settings.text_color
-%}
<div class="hh-home" id="hh-promo-{{ section.id }}">
  <section class="hh-promo hh-rv">
    {%- if img_src != blank -%}
      <img class="hh-promo__img" src="{{ img_src }}" alt="{{ section.settings.heading | escape }}" loading="lazy"
        {%- if img != blank %} srcset="{{ img | image_url: width: 1200 }} 1200w, {{ img | image_url: width: 2000 }} 2000w, {{ img | image_url: width: 2600 }} 2600w" sizes="100vw"{% endif -%}>
    {%- endif -%}
    <div class="hh-promo__veil"></div>
    <div class="hh-promo__in">
      {%- if section.settings.kicker != blank -%}<p class="hh-promo__kick" style="color: {{ tc }};">{{ section.settings.kicker }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="hh-promo__h" style="color: {{ tc }};">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.button_label != blank -%}<a class="hh-promo__btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>{%- endif -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .hh-promo { position: relative; min-height: 90vh; overflow: hidden; background: #2b2722; }
  .hh-promo__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 50% 8%; }
  .hh-promo__veil { position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(0,0,0,.58) 0%, rgba(0,0,0,.32) 24%, rgba(0,0,0,0) 54%); pointer-events: none; }
  .hh-promo__in { position: absolute; top: 8%; left: 0; right: 0; z-index: 2; text-align: center; padding: 0 24px; text-shadow: 0 2px 22px rgba(0,0,0,.6); }
  .hh-promo__kick { margin: 0 0 16px; font-size: 11px; letter-spacing: .3em; text-transform: uppercase; }
  .hh-home .hh-promo__h { font-size: clamp(40px, 5.6vw, 86px); line-height: 1.0; }
  .hh-promo__btn { display: inline-block; margin-top: 28px; background: #fff; color: #2a2722; border: 1px solid #fff; padding: 17px 44px; font-size: 11px; letter-spacing: .22em; text-transform: uppercase; transition: all .4s ease; text-shadow: none; box-shadow: 0 2px 18px rgba(0,0,0,.18); }
  .hh-promo__btn:hover { background: transparent; color: #fff; border-color: #fff; box-shadow: none; text-shadow: 0 2px 12px rgba(0,0,0,.5); }
  @media (max-width: 600px) { .hh-promo { min-height: 80vh; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Home — Promo banner",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_url", "label": "Or image URL (fallback)", "default": "https://cdn.shopify.com/s/files/1/0560/2600/5592/files/modern-coastal-interior-dining-space-with-teak-table-fulfily-2.jpg?v=1778011164" },
    { "type": "header", "content": "Text" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "New Season" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Autumn Collection" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Home — Promo banner" }]
}
{% endschema %}

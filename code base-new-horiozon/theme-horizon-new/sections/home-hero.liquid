{%- comment -%} Hedi's home — Hero. Full-screen image + heading + button. {%- endcomment -%}
{% render 'hedis-home-base' %}
{%- liquid
  assign img = section.settings.image
  assign img_src = section.settings.image_url
  if img != blank
    assign img_src = img | image_url: width: 2600
  endif
-%}
<div class="hh-home" id="hh-hero-{{ section.id }}">
  <section class="hh-hero">
    {%- if img_src != blank -%}
      <img class="hh-hero__img" src="{{ img_src }}" alt="{{ section.settings.heading | escape }}"
        {%- if img != blank %} srcset="{{ img | image_url: width: 1200 }} 1200w, {{ img | image_url: width: 2000 }} 2000w, {{ img | image_url: width: 2600 }} 2600w" sizes="100vw"{% endif -%}>
    {%- endif -%}
    <div class="hh-hero__scrim" style="opacity: {{ section.settings.overlay | divided_by: 100.0 }};"></div>
    <div class="hh-hero__in">
      {%- if section.settings.kicker != blank -%}<p class="hh-kick">{{ section.settings.kicker }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h1 class="hh-hero__title">{{ section.settings.heading }}</h1>{%- endif -%}
      {%- if section.settings.subtext != blank -%}<p class="hh-hero__sub">{{ section.settings.subtext }}</p>{%- endif -%}
      {%- if section.settings.button_label != blank -%}<a class="hh-btn hh-btn--light" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>{%- endif -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .hh-hero { position: relative; height: 92vh; min-height: 600px; background: #2b2722; overflow: hidden; }
  .hh-hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hh-hero__scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(0,0,0,1) 0%, rgba(0,0,0,.65) 42%, rgba(0,0,0,1) 100%); }
  .hh-hero__in { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 24px; text-shadow: 0 2px 26px rgba(0,0,0,.55); }
  .hh-hero__in .hh-kick { color: #fff; }
  .hh-home .hh-hero__title { color: #fff; font-size: clamp(46px, 6.6vw, 96px); max-width: 16ch; }
  .hh-hero__sub { margin: 20px 0 0; color: #fff; font-size: 15px; letter-spacing: .04em; max-width: 44ch; }
  @media (max-width: 600px) { .hh-hero { height: 84vh; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Home — Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_url", "label": "Or image URL (fallback)", "default": "https://cdn.shopify.com/s/files/1/0560/2600/5592/files/huxley-sofa-in-modern-spacious-living-room-with-natural-light-fulfily-0.jpg?v=1780164479" },
    { "type": "range", "id": "overlay", "label": "Image darkness", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 55 },
    { "type": "header", "content": "Text" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Hedi's Furniture" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Timeless pieces for a life well lived" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Handcrafted sofas, tables and lighting, designed to last for generations." },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Home — Hero" }]
}
{% endschema %}

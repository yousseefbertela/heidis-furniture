{%- assign picker_type = block.settings.picker_type -%}
{%- assign enable_border_top = block.settings.enable_border_top -%}
{%- assign enable_border_bottom = block.settings.enable_border_bottom -%}
{%- assign color_border = block.settings.color_border -%}
{%- assign product_swatch_option = settings.swatch | downcase -%}

<div class="productView-options{% if enable_border_top %} has-border-top{% endif %}{% if enable_border_bottom %} has-border-bottom{% endif %}" style="--color-border: {{ color_border }}">
  {%- if variantCount > 0 and product.has_only_default_variant != true -%}
    <div class="productView-variants halo-productOptions" id="product-option-{{ product.id }}" data-type="{{ picker_type }}">
      {%- if picker_type == 'button' -%}
        <variant-radios class="no-js-hidden product-option has-default" data-product="{{ product.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}">
          {%- for option in product.options_with_values -%}
            {%- assign is_swatch = false -%}
            {%- assign option_name = option.name | downcase -%}
            {%- if product_swatch_option contains option_name -%}
              {%- assign is_swatch = true -%}
            {%- endif -%}
            {%- assign swatch_type = settings.swatch_type -%}

            <fieldset class="js product-form__input{% if is_swatch %} product-form__swatch{% endif %} clearfix" data-product-attribute="set-rectangle" data-option-index="{{ forloop.index0 }}">
              <legend class="form__label">
                {{ option.name }}:
                <span data-header-option>{{ option.selected_value }}</span>
              </legend>

              {%- assign values = '' -%}
              {%- for variant in product.variants -%}
                {%- assign value = variant.options[forloop.parentloop.index0] -%}
                {%- unless values contains value -%}
                  {%- assign values = values | join: ';' | append: ';' | append: value | split: ';' -%}

                  {%- assign swatch_handle = value | handle -%}
                  {%- assign matched_color = shop.metaobjects['shopify--color-pattern'].values | where: "handle", swatch_handle | first -%}
                  {%- assign color_info = shop.metaobjects.color_info.values | where: "color", matched_color.id | first -%}

                  <input class="product-form__radio" type="radio" id="option-{{ product.id }}-{{ option.name }}-{{ forloop.index0 }}"
                         name="{{ option.name }}" value="{{ value | escape }}"
                         {% if option.selected_value == value %}checked{% endif %} data-variant-id="{{ variant.id }}">

                  {%- assign enable_variant_image = false -%}
                  {%- assign background_image = '' -%}
                  {%- assign background_color = '' -%}
                  {%- assign color_codes = false -%}

                  {%- if swatch_type == 'variant_image' and variant.image -%}
                    {%- assign enable_variant_image = true -%}
                    {%- assign background_image = variant.image | image_url: width: 100 -%}
                  {%- elsif swatch_type == 'metafields' -%}
                    {%- assign variant_color = variant.metafields.custom.variant_color -%}
                    {%- if variant_color -%}
                      {%- assign enable_variant_image = true -%}
                      {%- if variant_color contains '#' or variant_color contains 'rgb' or variant_color contains 'hsl' -%}
                        {%- assign color_codes = true -%}
                        {%- assign background_color = variant_color -%}
                      {%- else -%}
                        {%- assign background_image = variant_color | append: '.png' | file_url -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- elsif swatch_type == 'color' -%}
                    {%- assign enable_variant_image = true -%}
                    {%- assign background_image = value | handle | append: '.png' | file_url -%}
                  {%- endif -%}

                  <div class="swatch-wrapper">
                    <label class="product-form__label available" for="option-{{ product.id }}-{{ option.name }}-{{ forloop.index0 }}" data-variant-id="{{ variant.id }}">
                      <span class="pattern"
                        style="{% if color_codes %}background-color: {{ background_color }};{% elsif enable_variant_image %}background-image: url({{ background_image }}); background-size: cover;{% endif %}">
                      </span>
                    </label>

                    {%- if color_info -%}
                      <template class="swatch-hover-data">
                        <img class="fabric-image" src="{% if color_info.fabric_image %}{{ color_info.fabric_image | image_url: width: 300 }}{% elsif matched_color.image %}{{ matched_color.image | image_url: width: 300 }}{% else %}{{ swatch_handle | append: '.png' | file_url }}{% endif %}" />
                        <h4>{{ matched_color.name | default: value }}</h4>
                        <div class="attribute"><strong>Pattern:</strong> {{ color_info.pattern | default: 'N/A' }}</div>
                        <div class="attribute"><strong>Cleaning Code:</strong> <a href="https://hedisfurniture.com/pages/cleaningcode" target="_blank">{{ color_info.cleaning_code | default: 'N/A' }}</a></div>
                        <div class="attribute"><strong>Fabric Content:</strong> {{ color_info.fabric_content | default: 'N/A' }}</div>
                      </template>
                    {%- endif -%}
                  </div>
                {%- endunless -%}
              {%- endfor -%}
            </fieldset>
          {%- endfor -%}
          <script type="application/json">{{ product.variants | json }}</script>
        </variant-radios>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
